API_BASE_URL=http://10.0.2.2:5000
ENV=development
# Bật sau khi có android/app/google-services.json + lib/firebase_options.dart
ENABLE_FIREBASE=true
APP_NAME=SNAPSTUDY
AUTH_DEV_MODE=true
# OAuth Web client (client_type 3) — cùng project Firebase snapstudy-6fbd2
GOOGLE_SERVER_CLIENT_ID=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Khi đã có GEMINI_API_KEY: app dùng Gemini thật (không cần tắt *_DEV_MODE).
# Chỉ bật *_FORCE_MOCK=true nếu muốn ép dữ liệu mẫu dù có key.
AI_SUMMARY_DEV_MODE=false
AI_SUMMARY_FORCE_MOCK=false
FLASHCARDS_DEV_MODE=false
FLASHCARDS_FORCE_MOCK=false
QUIZ_DEV_MODE=false
QUIZ_FORCE_MOCK=false
MINDMAP_DEV_MODE=false
MINDMAP_FORCE_MOCK=false
OCR_ENGINE=auto
# auto = Gemini Vision nếu có GEMINI_API_KEY; mlkit = on-device; gemini = ép cloud
ENABLE_FCM=true
ENABLE_PUSH_REGISTRATION=true
PUSH_REGISTER_PATH=/api/notifications/devices

# Performance (Phase 15)
DASHBOARD_CACHE_TTL_SECONDS=45
SESSION_LIST_CACHE_TTL_SECONDS=30
IMAGE_CACHE_MAX_MB=120
IMAGE_CACHE_MAX_COUNT=200
